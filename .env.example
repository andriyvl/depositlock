# DepositLock environment variables
# Copy to:
# - .env.local for Next.js runtime (NEXT_PUBLIC_* only)
# - .env for Hardhat scripts (private keys + deploy vars)

############################################
# Next.js (client) - public values
############################################
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Read-only RPC endpoints
NEXT_PUBLIC_RPC_POLYGON=https://polygon-rpc.com
NEXT_PUBLIC_RPC_AMOY=https://rpc-amoy.polygon.technology/
NEXT_PUBLIC_RPC_ETHEREUM=
NEXT_PUBLIC_RPC_ARBITRUM=
NEXT_PUBLIC_RPC_OPTIMISM=https://mainnet.optimism.io
NEXT_PUBLIC_RPC_BASE=https://mainnet.base.org

# Optional default contract address for direct reads
NEXT_PUBLIC_CONTRACT_ADDRESS=

############################################
# Hardhat (server) - private values
############################################
PRIVATE_KEY=

# Network RPCs for deployments
POLYGON_RPC_URL=https://polygon-rpc.com
AMOY_RPC_URL=https://rpc-amoy.polygon.technology/
ETHEREUM_RPC_URL=
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org

# Deployment defaults (override per run if needed)
CONTRACT_AMOUNT=100
CONTRACT_DEADLINE_HOURS=168
CONTRACT_TITLE=Deposit Agreement
CONTRACT_DESCRIPTION=Secure deposit agreement created via DepositLock
CONTRACT_NETWORK_ID=eip155:137

# Stablecoin config for constructor
CONTRACT_TOKEN_SYMBOL=USDC
CONTRACT_TOKEN_ADDRESS=0x3c499c542cef5e3811e1192ce70d8cc03d5c3359
CONTRACT_TOKEN_DECIMALS=6
